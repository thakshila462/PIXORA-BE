# ============= REQUIRED (Set on Vercel) =============

# MongoDB connection string
# Get from: https://cloud.mongodb.com → Your Project → Connect → MongoDB Drivers
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/pixora-db?retryWrites=true&w=majority

# JWT secrets for authentication tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# Frontend URL (for CORS)
# Match your deployed frontend origin exactly
CLIENT_URL=https://pixora-fe.vercel.app

# ============= OPTIONAL =============

# Node environment
NODE_ENV=production

# Server port (Vercel uses PORT env var)
PORT=5000

# ============= LOCAL DEVELOPMENT =============
# For local testing, you can use:
# DB_URL=mongodb://localhost:27017/pixora-db
# NODE_ENV=development
# CLIENT_URL=http://localhost:5173
